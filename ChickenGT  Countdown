<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ChickenGT Countdown</title>

<!-- Clean cinematic font -->
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&display=swap" rel="stylesheet">

<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    height: 100vh;
    background: #050505;
    color: #e00000;
    font-family: 'Orbitron', sans-serif;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    overflow: hidden;
}

/* Animated fog effect */
body::before {
    content: "";
    position: absolute;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle at center, rgba(255,0,0,0.08) 0%, transparent 60%);
    animation: fogMove 20s linear infinite;
}

@keyframes fogMove {
    0% { transform: translate(-20%, -20%); }
    50% { transform: translate(20%, 20%); }
    100% { transform: translate(-20%, -20%); }
}

h1 {
    font-size: 3rem;
    letter-spacing: 6px;
    text-transform: uppercase;
    margin-bottom: 40px;
    text-shadow: 0 0 15px #ff0000aa;
    animation: pulseTitle 4s infinite;
    z-index: 2;
}

@keyframes pulseTitle {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.7; }
}

#countdown {
    display: flex;
    gap: 20px;
    z-index: 2;
}

.time-box {
    background: rgba(255,0,0,0.05);
    border: 1px solid rgba(255,0,0,0.3);
    padding: 20px 30px;
    text-align: center;
    backdrop-filter: blur(5px);
    transition: 0.3s ease;
}

.time-box:hover {
    transform: scale(1.05);
    border-color: red;
    box-shadow: 0 0 20px rgba(255,0,0,0.4);
}

.number {
    font-size: 2.5rem;
}

.label {
    font-size: 0.8rem;
    letter-spacing: 2px;
    margin-top: 5px;
    opacity: 0.6;
}

/* Subtle glitch flicker */
@keyframes glitch {
    0% { opacity: 1; }
    92% { opacity: 1; }
    93% { opacity: 0.2; }
    94% { opacity: 1; }
    95% { opacity: 0.4; }
    96% { opacity: 1; }
    100% { opacity: 1; }
}

body {
    animation: glitch 7s infinite;
}
</style>
</head>
<body>

<h1>ChickenGT Countdown</h1>

<div id="countdown">
    <div class="time-box">
        <div class="number" id="days">00</div>
        <div class="label">DAYS</div>
    </div>
    <div class="time-box">
        <div class="number" id="hours">00</div>
        <div class="label">HOURS</div>
    </div>
    <div class="time-box">
        <div class="number" id="minutes">00</div>
        <div class="label">MINUTES</div>
    </div>
    <div class="time-box">
        <div class="number" id="seconds">00</div>
        <div class="label">SECONDS</div>
    </div>
</div>

<script>
// 2 weeks countdown from first visit
const TWO_WEEKS = 14 * 24 * 60 * 60 * 1000;

let targetDate = localStorage.getItem("chickengtCountdown");

if (!targetDate) {
    targetDate = new Date().getTime() + TWO_WEEKS;
    localStorage.setItem("chickengtCountdown", targetDate);
}

const updateCountdown = () => {
    const now = new Date().getTime();
    const distance = targetDate - now;

    if (distance <= 0) {
        document.body.innerHTML = `
            <h1 style="font-size:4rem; text-shadow:0 0 30px red;">
                IT BEGINS.
            </h1>
        `;
        return;
    }

    const days = Math.floor(distance / (1000 * 60 * 60 * 24));
    const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
    const seconds = Math.floor((distance % (1000 * 60)) / 1000);

    document.getElementById("days").innerText = String(days).padStart(2, '0');
    document.getElementById("hours").innerText = String(hours).padStart(2, '0');
    document.getElementById("minutes").innerText = String(minutes).padStart(2, '0');
    document.getElementById("seconds").innerText = String(seconds).padStart(2, '0');
};

setInterval(updateCountdown, 1000);
updateCountdown();
</script>

</body>
</html>
